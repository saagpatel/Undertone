		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/ui": "^4.1.8",
		"jsdom": "^25.0.0",
		"typescript": "^5.6.3",
		"vite": "^6.4.3",
		"vitest": "^4.1.8"
	}
